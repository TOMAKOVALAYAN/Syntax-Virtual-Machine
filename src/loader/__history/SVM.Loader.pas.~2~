unit SVM.Loader;

interface

uses
  System.SysUtils,
  System.Classes,
  SVM.Common,
  SVM.CPU,
  SVM.Strings; // Metin havuzu deste­i ińin eklendi

type
  TSVMLoader = class
  public
    // Parametre say²s² 3'e ń²kar²ld²: FileName, ACPU ve AStrings
    class procedure LoadIntoCPU(const FileName: string; ACPU: TSVMCPU; AStrings: TSVMStringPool);
  end;

implementation

class procedure TSVMLoader.LoadIntoCPU(const FileName: string; ACPU: TSVMCPU; AStrings: TSVMStringPool);
var
  FS: TFileStream;
  Magic: array[0..7] of Byte;
  VerMajor, VerMinor: Byte;
  CodeSize: Integer;
  ByteCode: array of Byte;
begin
  if not FileExists(FileName) then
    raise Exception.Create('SVM Loader: Dosya bulunamad² -> ' + FileName);

  FS := TFileStream.Create(FileName, fmOpenRead);
  try
    // 1. ▌mza Kontrol³
    FS.ReadBuffer(Magic, 8);
    if not CompareMem(@Magic, @SVM_MAGIC, 8) then
      raise Exception.Create('SVM Loader: Geńersiz dosya imzas²!');

    // 2. Versiyon Bilgisi
    FS.ReadBuffer(VerMajor, 1);
    FS.ReadBuffer(VerMinor, 1);

    // 3. Kod Okuma (Geri kalan t³m byte'lar bytecode olarak kabul edilir)
    CodeSize := FS.Size - FS.Position;
    if CodeSize > 0 then
    begin
      SetLength(ByteCode, CodeSize);
      FS.ReadBuffer(ByteCode[0], CodeSize);

      // CPU'ya bytecode'u y³kle
      ACPU.LoadCode(ByteCode);
    end;

    // Not: Gelecekte String Pool'u dosyadan okumak istersen AStrings burada kullan²lacak.

    Writeln(Format('SVM Loader: %d byte y³klendi (Sanal Makine v%d.%d)', [CodeSize, VerMajor, VerMinor]));
  finally
    FS.Free;
  end;
end;

end.
