unit SVM.Loader;

interface

uses
  System.SysUtils, System.Classes, SVM.Common, SVM.CPU;

type
  TSVMLoader = class
  public
    class procedure LoadIntoCPU(const FileName: string; ACPU: TSVMCPU);
  end;

implementation

class procedure TSVMLoader.LoadIntoCPU(const FileName: string; ACPU: TSVMCPU);
var
  FS: TFileStream;
  Magic: array[0..7] of Byte;
  VerMajor, VerMinor: Byte;
  CodeSize: Integer;
  ByteCode: array of Byte;
begin
  if not FileExists(FileName) then
    raise Exception.Create('SVM Loader: Dosya bulunamad² -> ' + FileName);

  FS := TFileStream.Create(FileName, fmOpenRead);
  try
    // 1. ¦mza Kontrol³ (aminoglu)
    FS.ReadBuffer(Magic, 8);
    if not CompareMem(@Magic, @SVM_MAGIC, 8) then
      raise Exception.Create('SVM Loader: Geþersiz dosya imzas²!');

    // 2. Versiyon
    FS.ReadBuffer(VerMajor, 1);
    FS.ReadBuffer(VerMinor, 1);

    // 3. Kod Okuma
    CodeSize := FS.Size - FS.Position;
    SetLength(ByteCode, CodeSize);
    FS.ReadBuffer(ByteCode[0], CodeSize);

    // CPU'ya aktar
    ACPU.LoadCode(ByteCode);
    Writeln(Format('SVM Loader: %d byte y³klendi (v%d.%d)', [CodeSize, VerMajor, VerMinor]));
  finally
    FS.Free;
  end;
end;

end.