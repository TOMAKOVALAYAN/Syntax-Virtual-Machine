unit SVM.Common;

interface

uses
  System.SysUtils;

const
  // SVM Dosya Ýmzasý (Magic Number: "aminoglu")
  SVM_MAGIC: array[0..7] of Byte = (97, 109, 105, 110, 111, 103, 108, 117);

  // Versiyon Bilgisi
  SVM_VER_MAJOR = 1;
  SVM_VER_MINOR = 0;

type
  { SVM Ýţlem Kodlarý (Opcodes) }
  TSVMOpcode = (
    // --- Temel ve Yýđýn Ýţlemleri ($00 - $0D) ---
    opNOP     = $00,  // Ýţlem yapma
    opPUSH_I  = $01,  // Yýđýna tam sayý (Int64) koy
    opPUSH_F  = $02,  // Yýđýna ondalýklý sayý (Double) koy
    opPUSH_S  = $03,  // Yýđýna metin (String) koy
    opPOP     = $04,  // Yýđýnýn tepesindeki deđeri at
    opPRINT   = $09,  // Yýđýndaki deđeri konsola yazdýr
    opDUP     = $0D,  // Yýđýnýn tepesindeki deđeri kopyala

    // --- Aritmetik Ýţlemler ($05 - $08, $1A - $1B) ---
    opADD     = $05,  // Toplama
    opSUB     = $06,  // Çýkarma
    opMUL     = $07,  // Çarpma
    opDIV     = $08,  // Bölme
    opMOD     = $1A,  // Kalan bulma (Modulus)
    opPOW     = $1B,  // Üs alma (Power)

    // --- Karţýlaţtýrma Ýţlemleri ($0E - $13) ---
    opEQ      = $0E,  // Eţit mi? (==)
    opNEQ     = $0F,  // Eţit deđil mi? (!=)
    opGT      = $10,  // Büyük mü? (>)
    opLT      = $11,  // Küçük mü? (<)
    opGTE     = $12,  // Büyük veya eţit mi? (>=)
    opLTE     = $13,  // Küçük veya eţit mi? (<=)

    // --- Akýţ Kontrolü ($0A - $17, $FF) ---
    opJMP     = $0A,  // Koţulsuz zýpla
    opJZ      = $0B,  // Deđer 0 ise zýpla
    opJNZ     = $0C,  // Deđer 0 deđilse zýpla
    opCALL    = $16,  // Fonksiyon çađýr
    opRET     = $17,  // Fonksiyondan dön
    opHALT    = $FF,  // Programý durdur

    // --- Bellek Yönetimi (Global & Yerel) ($14 - $51) ---
    opSTORE   = $14,  // Global deđiţkene kaydet
    opLOAD    = $15,  // Global deđiţkenden oku
    opSTORE_L = $18,  // Yerel deđiţkene (Stack Frame) kaydet
    opLOAD_L  = $19,  // Yerel deđiţkenden oku
    opENTER   = $50,  // Local Frame oluţtur
    opLEAVE   = $51,  // Local Frame'i kapat

    // --- Mantýksal Operatörler ($30 - $32) ---
    opAND     = $30,  // Mantýksal VE
    opOR      = $31,  // Mantýksal VEYA
    opNOT     = $32,  // Mantýksal DEĐÝL

    // --- Tip Dönüţümü ve Giriţ ($52 - $54) ---
    opCAST_I  = $52,  // Float -> Int (Round/Trunc)
    opCAST_F  = $53,  // Int -> Float
    opINPUT   = $54,  // Kullanýcýdan veri al

    // --- Dinamik Bellek (Heap) & Dizi Ýţlemleri ($20 - $24) ---
    opALLOC   = $20,  // Heap'ten yer ayýr
    opSSET    = $21,  // Diziye/Heap'e deđer yaz
    opSGET    = $22,  // Dizi/Heap'ten deđer oku
    opFREE    = $23,  // Belleđi serbest býrak
    opLEN     = $24,  // Blođun boyutunu al

    // --- String Manipülasyonu ($40 - $41) ---
    opCONCAT  = $40,  // String birleţtir
    opSTRLEN  = $41   // String uzunluđu
  );

// Debug sýrasýnda opcode isimlerini yazdýrmak için yardýmcý fonksiyon
function OpcodeToString(Op: TSVMOpcode): string;

implementation

function OpcodeToString(Op: TSVMOpcode): string;
begin
  case Op of
    opNOP: Result := 'NOP';
    opPUSH_I: Result := 'PUSH_I';
    opPUSH_F: Result := 'PUSH_F';
    opPUSH_S: Result := 'PUSH_S';
    opPOP: Result := 'POP';
    opPRINT: Result := 'PRINT';
    opDUP: Result := 'DUP';
    opADD: Result := 'ADD';
    opSUB: Result := 'SUB';
    opMUL: Result := 'MUL';
    opDIV: Result := 'DIV';
    opMOD: Result := 'MOD';
    opPOW: Result := 'POW';
    opEQ: Result := 'EQ';
    opNEQ: Result := 'NEQ';
    opGT: Result := 'GT';
    opLT: Result := 'LT';
    opGTE: Result := 'GTE';
    opLTE: Result := 'LTE';
    opJMP: Result := 'JMP';
    opJZ: Result := 'JZ';
    opJNZ: Result := 'JNZ';
    opCALL: Result := 'CALL';
    opRET: Result := 'RET';
    opHALT: Result := 'HALT';
    opSTORE: Result := 'STORE';
    opLOAD: Result := 'LOAD';
    opSTORE_L: Result := 'STORE_L';
    opLOAD_L: Result := 'LOAD_L';
    opENTER: Result := 'ENTER';
    opLEAVE: Result := 'LEAVE';
    opAND: Result := 'AND';
    opOR: Result := 'OR';
    opNOT: Result := 'NOT';
    opCAST_I: Result := 'CAST_I';
    opCAST_F: Result := 'CAST_F';
    opINPUT: Result := 'INPUT';
    opALLOC: Result := 'ALLOC';
    opSSET: Result := 'SSET';
    opSGET: Result := 'SGET';
    opFREE: Result := 'FREE';
    opLEN: Result := 'LEN';
    opCONCAT: Result := 'CONCAT';
    opSTRLEN: Result := 'STRLEN';
    else Result := 'UNKNOWN';
  end;
end;

end.
