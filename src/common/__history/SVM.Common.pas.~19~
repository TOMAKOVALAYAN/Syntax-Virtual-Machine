unit SVM.Common;

interface

const
  // SVM Dosya Żmzasż (Magic Number: "aminoglu")
  SVM_MAGIC: array[0..7] of Byte = (97, 109, 105, 110, 111, 103, 108, 117);

  // Versiyon Bilgisi
  SVM_VER_MAJOR = 1;
  SVM_VER_MINOR = 0;

type
  { SVM Żžlem Kodlarż (Opcodes) }
  TSVMOpcode = (
    // --- Temel Żžlemler ($00 - $0D) ---
    opNOP     = $00,  // Żžlem yapma
    opPUSH_I  = $01,  // Yżšżna tam sayż (Int64) koy
    opPUSH_F  = $02,  // Yżšżna ondalżklż sayż (Double) koy
    opPUSH_S  = $03,  // Yżšżna metin (String) koy
    opPOP     = $04,  // Yżšżnżn tepesindeki dešeri at
    opDUP     = $0D,  // Yżšżnżn tepesindeki dešeri kopyala

    // --- Aritmetik Żžlemler ($05 - $08 + Yeni) ---
    opADD     = $05,  // Toplama
    opSUB     = $06,  // Ēżkarma
    opMUL     = $07,  // Ēarpma
    opDIV     = $08,  // Bölme
    opMOD     = $1A,  // Kalan bulma (Modulus)
    opPOW     = $1B,  // Üs alma (Power)

    // --- Karžżlažtżrma Żžlemleri ($0E - $13) ---
    opEQ      = $0E,  // Ežit mi? (==)
    opNEQ     = $0F,  // Ežit dešil mi? (!=)
    opGT      = $10,  // Büyük mü? (>)
    opLT      = $11,  // Küēük mü? (<)
    opGTE     = $12,  // Büyük veya ežit mi? (>=)
    opLTE     = $13,  // Küēük veya ežit mi? (<=)

    // --- Mantżksal Operatörler ($30 - $32) ---
    opAND     = $30,  // Mantżksal VE
    opOR      = $31,  // Mantżksal VEYA
    opNOT     = $32,  // Mantżksal DEŠŻL

    // --- Akżž Kontrolü ($0A - $17, $FF) ---
    opJMP     = $0A,  // Kožulsuz zżpla
    opJZ      = $0B,  // Dešer 0 ise zżpla
    opJNZ     = $0C,  // Dešer 0 dešilse zżpla
    opCALL    = $16,  // Fonksiyon ēašżr
    opRET     = $17,  // Fonksiyondan dön
    opHALT    = $FF,  // Programż durdur

    // --- Dešižken ve Bellek Yönetimi ($14 - $19) ---
    opSTORE   = $14,  // Global dešižkene kaydet
    opLOAD    = $15,  // Global dešižkenden oku
    opSTORE_L = $18,  // Yerel dešižkene (Stack Frame) kaydet
    opLOAD_L  = $19,  // Yerel dešižkenden oku

    // --- Dinamik Bellek (Heap) & Dizi Żžlemleri ($20 - $24) ---
    opALLOC   = $20,  // Yżšżndan boyut alżr, Heap'ten yer ayżrżp adres döner
    opSSET    = $21,  // Diziye dešer yaz: [Adres, Indeks, Dešer]
    opSGET    = $22,  // Diziden dešer oku: [Adres, Indeks]
    opFREE    = $23,  // Bellek blošunu DEAD olarak ižaretle
    opLEN     = $24,  // Blošun boyutunu (metadata) yżšżna basar

    // --- String Manipülasyonu ($40 - $41) ---
    opCONCAT  = $40,  // Żki stringi birležtirir
    opSTRLEN  = $41,  // String uzunlušunu döner

    // --- Ēżktż ---
    opPRINT   = $09   // Yżšżndaki dešeri konsola yazdżr
  );

implementation

end.
