unit SVM.Common;

interface

const
  SVM_MAGIC: array[0..7] of Byte = (97, 109, 105, 110, 111, 103, 108, 117);
  SVM_VER_MAJOR = 1;
  SVM_VER_MINOR = 0;

type
  TSVMOpcode = (
    opNOP    = $00,
    opPUSH_I = $01,
    opPUSH_F = $02,
    opPUSH_S = $03,
    opPOP    = $04,
    opADD    = $05,
    opSUB    = $06,
    opMUL    = $07,
    opDIV    = $08,
    opPRINT  = $09,
    // --- Akýþ Kontrolü (Jump) Komutlarý ---
    opJMP    = $0A,  // Koþulsuz zýpla (Target: Int64 adres)
    opJZ     = $0B,  // Zero ise zýpla (Stack'teki deðer 0 ise)
    opJNZ    = $0C,  // Not Zero ise zýpla (Stack'teki deðer 0 deðilse)
    // --------------------------------------
    opHALT   = $FF,
    opDUP    = $0D ,
    opEQ     = $0E,  // Eþit mi? (Equal)
    opNEQ    = $0F,  // Eþit deðil mi? (Not Equal)
