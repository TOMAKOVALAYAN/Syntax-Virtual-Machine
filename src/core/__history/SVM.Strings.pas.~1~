unit SVM.Strings;

interface

uses
  System.SysUtils, System.Classes, SVM.Types;

type
  TSVMStringPool = class
  private
    FStrings: TList; // Bellekteki PChar listesi
  public
    constructor Create;
    destructor Destroy; override;

    // Yeni bir string oluĢturur ve adresini dŲner
    function Intern(const Value: string): PChar;
    // ›ki stringi birleĢtirir (Concatenation)
    function Combine(S1, S2: PChar): PChar;
    // Belleūi temizler
    procedure Clear;
  end;

implementation

constructor TSVMStringPool.Create;
begin
  FStrings := TList.Create;
end;

destructor TSVMStringPool.Destroy;
begin
  Clear;
  FStrings.Free;
  inherited;
end;

function TSVMStringPool.Intern(const Value: string): PChar;
var
  P: PChar;
begin
  P := StrNew(PChar(Value));
  FStrings.Add(P);
  Result := P;
end;

function TSVMStringPool.Combine(S1, S2: PChar): PChar;
var
  Combined: string;
begin
  Combined := StrPas(S1) + StrPas(S2);
  Result := Intern(Combined);
end;

procedure TSVMStringPool.Clear;
var
  i: Integer;
begin
  for i := 0 to FStrings.Count - 1 do
    StrDispose(PChar(FStrings[i]));
  FStrings.Clear;
end;

end.
