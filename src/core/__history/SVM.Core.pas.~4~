unit SVM.Core;

interface

uses
  SVM.Common, System.SysUtils,System.TypInfo;

type
  TSVM = class
  private
    // Stack: HŁcrelerin dizisi
    FStack: array[0..1024] of TSVMCell;
    FSP: Integer; // Stack Pointer (Yżūżn imleci)

    // Program Counter (›mleÁ)
    FPC: Integer;
  public
    constructor Create;

    // Temel Stack ›Ģlemleri
    procedure Push(const Value: TSVMCell);
    function Pop: TSVMCell;

    // Debug: Stack'in durumunu gŲr
    procedure DumpStack;
    procedure TSVM.LoadFromSyasm(const FileName: string);
var
  FS: TFileStream;
  Magic: array[0..7] of Byte;
  VerMajor, VerMinor: Byte;
  CodeSize: Integer;
begin
  if not FileExists(FileName) then
    raise Exception.Create('Hata: .syasm dosyasż bulunamadż: ' + FileName);

  FS := TFileStream.Create(FileName, fmOpenRead);
  try
    // 1. ›mza KontrolŁ (aminoglu)
    FS.ReadBuffer(Magic, 8);
    if not CompareMem(@Magic, @SVM_MAGIC, 8) then
      raise Exception.Create('Hata: GeÁersiz dosya imzasż! (aminoglu bulunamadż)');

    // 2. Versiyon KontrolŁ
    FS.ReadBuffer(VerMajor, 1);
    FS.ReadBuffer(VerMinor, 1);
    Writeln(Format('Dosya Versiyonu: %d.%d', [VerMajor, VerMinor]));

    // 3. Kod Boyutu ve Bytecode YŁkleme
    // Dosyanżn geri kalanżnż kod olarak kabul ediyoruz
    CodeSize := FS.Size - FS.Position;
    SetLength(FCode, CodeSize);
    FS.ReadBuffer(FCode[0], CodeSize);

    Writeln(Format('BaĢarżyla yŁklendi: %d byte kod alżndż.', [CodeSize]));
    FPC := 0; // Program sayacżnż baĢa al
  finally
    FS.Free;
  end;
end;
  end;

implementation

constructor TSVM.Create;
begin
  FSP := -1; // Stack boĢ
  FPC := 0;
end;

procedure TSVM.Push(const Value: TSVMCell);
begin
  if FSP >= High(FStack) then
    raise Exception.Create('Stack Overflow!');

  Inc(FSP);
  FStack[FSP] := Value;
end;

function TSVM.Pop: TSVMCell;
begin
  if FSP < 0 then
    raise Exception.Create('Stack Underflow!');

  Result := FStack[FSP];
  Dec(FSP);
end;

procedure TSVM.DumpStack;
var
  i: Integer;
begin
  Writeln('--- STACK DUMP ---');
  if FSP = -1 then Writeln('(Empty)');
  for i := FSP downto 0 do
    Writeln(Format('[%d]: Type=%s', [i, GetEnumName(TypeInfo(TValueType), Ord(FStack[i].vType))]));
  Writeln('------------------');
end;

end.