unit SVM.Native;

interface

uses
  System.SysUtils, Winapi.Windows, System.Generics.Collections, SVM.Types, SVM.Common;

type
  { DLL fonksiyon çađrýmý için parametre tipleri }
  TNativeArgType = (atInt, atFloat, atString, atPtr);

  TSVMNativeBridge = class
  private
    FLibraries: TDictionary<string, THandle>;
  public
    constructor Create;
    destructor Destroy; override;

    function LoadLib(const ALibName: string): THandle;
    procedure FreeLib(AHandle: THandle);

    {
      Dinamik Fonksiyon Çađrýsý:
      - AHandle: DLL Handle
      - AFuncName: Fonksiyon Adý
      - AArgs: SVM Yýđýndan gelen parametreler
    }
    function CallFunc(AHandle: THandle; const AFuncName: string; const AArgs: array of TSVMCell): TSVMCell;
  end;

implementation

constructor TSVMNativeBridge.Create;
begin
  FLibraries := TDictionary<string, THandle>.Create;
end;

destructor TSVMNativeBridge.Destroy;
var
  Lib: THandle;
begin
  for Lib in FLibraries.Values do
    FreeLibrary(Lib);
  FLibraries.Free;
  inherited;
end;

function TSVMNativeBridge.LoadLib(const ALibName: string): THandle;
begin
  if not FLibraries.TryGetValue(ALibName.ToLower, Result) then
  begin
    Result := LoadLibrary(PChar(ALibName));
    if Result = 0 then
      raise Exception.Create(Format('DLL Yuklenemedi: %s (Hata Kodu: %d)', [ALibName, GetLastError]));
    FLibraries.Add(ALibName.ToLower, Result);
  end;
end;

procedure TSVMNativeBridge.FreeLib(AHandle: THandle);
var
  Pair: TPair<string, THandle>;
  TargetKey: string;
begin
  TargetKey := '';
  for Pair in FLibraries do
    if Pair.Value = AHandle then
    begin
      TargetKey := Pair.Key;
      Break;
    end;

  if TargetKey <> '' then
  begin
    FreeLibrary(AHandle);
    FLibraries.Remove(TargetKey);
  end;
end;

function TSVMNativeBridge.CallFunc(AHandle: THandle; const AFuncName: string; const AArgs: array of TSVMCell): TSVMCell;
var
  FuncPtr: Pointer;
  ArgList: array of NativeUInt;
  I: Integer;
  ResInt: NativeUInt;
  ResFloat: Double;
  IsFloatResult: Boolean;
begin
  FuncPtr := GetProcAddress(AHandle, PChar(AFuncName));
  if FuncPtr = nil then
    raise Exception.Create('DLL Fonksiyonu bulunamadi: ' + AFuncName);

  SetLength(ArgList, Length(AArgs));
  IsFloatResult := False; // Varsayýlan tam sayý dönüţü

  // 1. Argümanlarý Hazýrla (Marshalling)
  for I := 0 to High(AArgs) do
  begin
    case AArgs[I].vType of
      vtInt:    ArgList[I] := NativeUInt(AArgs[I].AsInt);
      vtFloat:  ArgList[I] := NativeUInt(Trunc(AArgs[I].AsFloat)); // Pointer olarak geçilecekse
      vtString: ArgList[I] := NativeUInt(PChar(AArgs[I].AsString));
    end;
  end;

  // 2. Dinamik Assembly Çađrýsý (x86 / x64 Uyumluluk Katmaný)
  // Not: Delphi'nin TValue veya System.Rtti mekanizmasý yerine
  // en düţük seviyeli çađýrma protokolünü kullanýyoruz.
  try
    {$IFDEF CPUX86}
    asm
      push ebx
      mov ebx, ArgList
      mov ecx, Length(ArgList)
      test ecx, ecx
      jz @no_args

      // Argümanlarý yýđýna tersten diz (stdcall/cdecl)
    @loop_args:
      dec ecx
      mov eax, [ebx + ecx * 4]
      push eax
      test ecx, ecx
      jnz @loop_args

    @no_args:
      call FuncPtr
      mov ResInt, eax
      // Float dönüţ kontrolü (ST0 register'ý)
      fstp ResFloat
      pop ebx
    end;
    {$ENDIF}

    {$IFDEF CPUX64}
    // x64 için Windows FastCall protokolü (RCX, RDX, R8, R9 + Stack)
    // Bu kýsým genellikle System.Rtti.TValue.Invoke ile daha güvenli çözülür
    // Ancak düţük seviye kontrol için manuel stack alignment gerekir.
    raise Exception.Create('x64 Native Bridge için RTTI Invoke katmaný aktif edilmeli.');
    {$ENDIF}

    // Dönüţ deđerini belirle (Hangi tip döneceđini basitçe tahmin ediyoruz veya int dönüyoruz)
    Result := TSVMCell.CreateInt(ResInt);

  except
    on E: Exception do
      raise Exception.Create('Native Call Hatasi: ' + E.Message);
  end;
end;

end.
