unit SVM.Strings;

interface

uses
  System.SysUtils, System.Classes, System.Generics.Collections;

type
  TSVMStringPool = class
  private
    { PChar adreslerini yönetmek için jenerik liste }
    FStrings: TList<PChar>;
    { Ayný metnin tekrar eklenmesini önlemek için opsiyonel bir kontrol eklenebilir }
  public
    constructor Create;
    destructor Destroy; override;

    { Yeni bir string oluţturur, havuza ekler ve adresini (PChar) döner }
    function Intern(const Value: string): PChar;

    { Ýki PChar'ý güvenli bir ţekilde birleţtirir ve yeni sonucu havuza alýr }
    function Combine(S1, S2: PChar): PChar;

    { Tüm string belleklerini serbest býrakýr }
    procedure Clear;
  end;

implementation

constructor TSVMStringPool.Create;
begin
  inherited Create;
  FStrings := TList<PChar>.Create;
end;

destructor TSVMStringPool.Destroy;
begin
  Clear;
  FStrings.Free;
  inherited;
end;

function TSVMStringPool.Intern(const Value: string): PChar;
var
  P: PChar;
begin
  if Value = '' then Exit(nil);

  { StrNew bellekten yer ayýrýr ve içeriđi kopyalar (#0 terminatörü dahil) }
  P := StrNew(PChar(Value));
  FStrings.Add(P);
  Result := P;
end;

function TSVMStringPool.Combine(S1, S2: PChar): PChar;
var
  Str1, Str2: string;
begin
  { PChar'larý Delphi stringlerine dönüţtür (Nil kontrolü ile) }
  if S1 <> nil then Str1 := StrPas(S1) else Str1 := '';
  if S2 <> nil then Str2 := StrPas(S2) else Str2 := '';

  { Birleţtir ve tekrar Intern et (Böylece yeni string de havuzun korumasý altýna girer) }
  Result := Intern(Str1 + Str2);
end;

procedure TSVMStringPool.Clear;
var
  P: PChar;
begin
  { Listedeki tüm PChar'lar için ayrýlan belleđi tek tek boţalt }
  for P in FStrings do
  begin
    if P <> nil then
      StrDispose(P);
  end;
  FStrings.Clear;
end;

end.
