unit SVM.Core;

interface

uses
  SVM.Common, System.SysUtils;

type
  TSVM = class
  private
    // Stack: Hücrelerin dizisi
    FStack: array[0..1024] of TSVMCell;
    FSP: Integer; // Stack Pointer (Yýđýn imleci)

    // Program Counter (Ýmleç)
    FPC: Integer;
  public
    constructor Create;

    // Temel Stack Ýţlemleri
    procedure Push(const Value: TSVMCell);
    function Pop: TSVMCell;

    // Debug: Stack'in durumunu gör
    procedure DumpStack;
  end;

implementation

constructor TSVM.Create;
begin
  FSP := -1; // Stack boţ
  FPC := 0;
end;

procedure TSVM.Push(const Value: TSVMCell);
begin
  if FSP >= High(FStack) then
    raise Exception.Create('Stack Overflow!');

  Inc(FSP);
  FStack[FSP] := Value;
end;

function TSVM.Pop: TSVMCell;
begin
  if FSP < 0 then
    raise Exception.Create('Stack Underflow!');

  Result := FStack[FSP];
  Dec(FSP);
end;

procedure TSVM.DumpStack;
var
  i: Integer;
begin
  Writeln('--- STACK DUMP ---');
  if FSP = -1 then Writeln('(Empty)');
  for i := FSP downto 0 do
    Writeln(Format('[%d]: Type=%s', [i, GetEnumName(TypeInfo(TValueType), Ord(FStack[i].vType))]));
  Writeln('------------------');
end;

end.