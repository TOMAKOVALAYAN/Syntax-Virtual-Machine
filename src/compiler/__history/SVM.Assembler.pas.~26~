unit SVM.Assembler;

interface

uses
  System.SysUtils, System.Classes, System.Generics.Collections, System.IOUtils,
  SVM.Common;

type
  TSVMAssembler = class
  private
    class function GetStringLiteral(const ALine: string): string;
    class function CleanLine(const ALine: string): string;
    class function ProcessImports(const MainFilePath: string; ProcessedFiles: TStringList): string;
  public
    class function Assemble(const ASource: string): TBytes;
    class function BuildProject(const MainFilePath: string): TBytes;
  end;

implementation

{ Yorumlarż temizler ve satżrż budar }
class function TSVMAssembler.CleanLine(const ALine: string): string;
var
  CIdx: Integer;
begin
  Result := ALine.Trim;
  CIdx := Result.IndexOf(';');
  if CIdx <> -1 then Result := Result.Substring(0, CIdx).Trim;
  CIdx := Result.IndexOf('//');
  if CIdx <> -1 then Result := Result.Substring(0, CIdx).Trim;
end;

{ Tżrnak iēindeki metni ayżklar }
class function TSVMAssembler.GetStringLiteral(const ALine: string): string;
var
  First, Last: Integer;
begin
  First := ALine.IndexOf('"');
  Last := ALine.LastIndexOf('"');
  if (First <> -1) and (Last > First) then
    Result := ALine.Substring(First + 1, Last - First - 1)
  else
    Result := '';
end;

{ IMPORT dosyalarżnż birležtirir }
class function TSVMAssembler.ProcessImports(const MainFilePath: string; ProcessedFiles: TStringList): string;
var
  Lines: TStringList;
  FullCode: TStringBuilder;
  I: Integer;
  Line, ImportFile, BasePath, CanonicalPath: string;
begin
  CanonicalPath := TPath.GetFullPath(MainFilePath).ToUpper;
  if ProcessedFiles.IndexOf(CanonicalPath) <> -1 then Exit('');
  ProcessedFiles.Add(CanonicalPath);

  if not TFile.Exists(MainFilePath) then
    raise Exception.Create('SVM Assembler Hatasż: Dosya bulunamadż -> ' + MainFilePath);

  BasePath := ExtractFilePath(MainFilePath);
  Lines := TStringList.Create;
  FullCode := TStringBuilder.Create;
  try
    Lines.LoadFromFile(MainFilePath, TEncoding.UTF8);
    for I := 0 to Lines.Count - 1 do
    begin
      Line := CleanLine(Lines[I]);
      if Line.StartsWith('IMPORT', True) then
      begin
        ImportFile := GetStringLiteral(Lines[I]).Trim;
        if ImportFile <> '' then
          FullCode.AppendLine(ProcessImports(TPath.Combine(BasePath, ImportFile), ProcessedFiles));
      end
      else if Line <> '' then
        FullCode.AppendLine(Line);
    end;
    Result := FullCode.ToString;
  finally
    Lines.Free;
    FullCode.Free;
  end;
end;

{ Proje olužturucu }
class function TSVMAssembler.BuildProject(const MainFilePath: string): TBytes;
var
  CombinedSource: string;
  Processed: TStringList;
begin
  Processed := TStringList.Create;
  try
    CombinedSource := ProcessImports(MainFilePath, Processed);

    // Büyük/Küēük harf duyarsżz kontrol
    if not CombinedSource.ToLower.Contains('main:') then
       raise Exception.Create('Linker Hatasż: "main:" etiketi bulunamadż!');

    // Kodu birležtirirken JMP satżrżndan sonra temiz bir satżr bažż bżrak
    CombinedSource := 'JMP @main' + sLineBreak + CombinedSource;

    Result := Assemble(CombinedSource);
  finally
    Processed.Free;
  end;
end;

{ Assembler Core }
class function TSVMAssembler.Assemble(const ASource: string): TBytes;
var
  Lines: TStringList;
  Output: TMemoryStream;
  Labels: TDictionary<string, Int64>;
  I: Integer;
  Line, Command, TargetLabel: string;
  Parts: TArray<string>;
  UTF8Str: RawByteString;
  TempByte: Byte;
  TempInt: Int64;
  TempFloat: Double;
  TempLen: Integer;

  procedure WriteJumpTarget(const ATarget: string);
  var Addr: Int64;
  begin
    TargetLabel := ATarget.Trim.ToUpper;
    if TargetLabel.StartsWith('@') then
    begin
      if Labels.TryGetValue(TargetLabel, Addr) then
        Output.Write(Addr, 8)
      else
        raise Exception.Create('SVM Assembler Hatasż: Tanżmsżz etiket -> ' + TargetLabel);
    end
    else begin
      Addr := StrToInt64Def(TargetLabel, 0);
      Output.Write(Addr, 8);
    end;
  end;

begin
  Lines := TStringList.Create;
  Output := TMemoryStream.Create;
  Labels := TDictionary<string, Int64>.Create;
  try
    Lines.Text := ASource;

    // --- 1. GEĒŻŽ: ETŻKETLERŻ VE ADRESLERŻ HARŻTALAMA ---
    TempInt := 0;
    for I := 0 to Lines.Count - 1 do
    begin
      Line := CleanLine(Lines[I]);
      if (Line = '') then Continue;

      // Etiket Tanżmż
      if Line.EndsWith(':') then
      begin
        var Lbl := '@' + Line.Substring(0, Line.Length - 1).Trim.ToUpper;
        Labels.AddOrSetValue(Lbl, TempInt);
        Continue;
      end;

      Parts := Line.Split([' '], TStringSplitOptions.ExcludeEmpty);
      if Length(Parts) = 0 then Continue;
      Command := Parts[0].ToUpper;

      if (Command = 'PUSH_I') or (Command = 'PUSH_F') or
         (Command = 'JMP') or (Command = 'JZ') or (Command = 'JNZ') or (Command = 'CALL') then
        Inc(TempInt, 9)
      else if (Command = 'PUSH_S') then
      begin
        UTF8Str := UTF8Encode(GetStringLiteral(Lines[I]));
        Inc(TempInt, 1 + 4 + Length(UTF8Str));
      end
      else if (Command = 'STORE') or (Command = 'LOAD') or
              (Command = 'STORE_L') or (Command = 'LOAD_L') or (Command = 'ENTER') then
        Inc(TempInt, 2)
      else
        Inc(TempInt, 1);
    end;

    // --- 2. GEĒŻŽ: BYTECODE YAZIMI ---
    for I := 0 to Lines.Count - 1 do
    begin
      Line := CleanLine(Lines[I]);
      if (Line = '') or Line.EndsWith(':') then Continue;

      Parts := Line.Split([' '], TStringSplitOptions.ExcludeEmpty);
      if Length(Parts) = 0 then Continue;
      Command := Parts[0].ToUpper;

      // Opcodes
      if Command = 'PUSH_I' then begin
        TempByte := Byte(opPUSH_I); Output.Write(TempByte, 1);
        TempInt := StrToInt64Def(Parts[1], 0); Output.Write(TempInt, 8);
      end
      else if Command = 'PUSH_F' then begin
        TempByte := Byte(opPUSH_F); Output.Write(TempByte, 1);
        TempFloat := StrToFloatDef(Parts[1], 0, TFormatSettings.Invariant); Output.Write(TempFloat, 8);
      end
      else if Command = 'PUSH_S' then begin
        UTF8Str := UTF8Encode(GetStringLiteral(Lines[I]));
        TempLen := Length(UTF8Str);
        TempByte := Byte(opPUSH_S); Output.Write(TempByte, 1);
        Output.Write(TempLen, 4);
        if TempLen > 0 then Output.Write(UTF8Str[1], TempLen);
      end
      else if (Command = 'STORE') or (Command = 'LOAD') then begin
        if Command = 'STORE' then TempByte := Byte(opSTORE) else TempByte := Byte(opLOAD);
        Output.Write(TempByte, 1);
        TempByte := StrToIntDef(Parts[1], 0); Output.Write(TempByte, 1);
      end
      else if (Command = 'STORE_L') or (Command = 'LOAD_L') then begin
        if Command = 'STORE_L' then TempByte := Byte(opSTORE_L) else TempByte := Byte(opLOAD_L);
        Output.Write(TempByte, 1);
        TempByte := Byte(ShortInt(StrToInt(Parts[1]))); Output.Write(TempByte, 1);
      end
      else if Command = 'ENTER' then begin
        TempByte := Byte(opENTER); Output.Write(TempByte, 1);
        TempByte := StrToIntDef(Parts[1], 0); Output.Write(TempByte, 1);
      end
      else if (Command = 'CALL') or (Command = 'JMP') or (Command = 'JZ') or (Command = 'JNZ') then begin
        if Command = 'CALL' then TempByte := Byte(opCALL)
        else if Command = 'JMP' then TempByte := Byte(opJMP)
        else if Command = 'JZ' then TempByte := Byte(opJZ)
        else TempByte := Byte(opJNZ);
        Output.Write(TempByte, 1); WriteJumpTarget(Parts[1]);
      end
      else if Command = 'ADD' then begin TempByte := Byte(opADD); Output.Write(TempByte, 1); end
      else if Command = 'SUB' then begin TempByte := Byte(opSUB); Output.Write(TempByte, 1); end
      else if Command = 'MUL' then begin TempByte := Byte(opMUL); Output.Write(TempByte, 1); end
      else if Command = 'DIV' then begin TempByte := Byte(opDIV); Output.Write(TempByte, 1); end
      else if Command = 'MOD' then begin TempByte := Byte(opMOD); Output.Write(TempByte, 1); end
      else if Command = 'POW' then begin TempByte := Byte(opPOW); Output.Write(TempByte, 1); end
      else if Command = 'EQ'  then begin TempByte := Byte(opEQ);  Output.Write(TempByte, 1); end
      else if Command = 'NEQ' then begin TempByte := Byte(opNEQ); Output.Write(TempByte, 1); end
      else if Command = 'GT'  then begin TempByte := Byte(opGT);  Output.Write(TempByte, 1); end
      else if Command = 'LT'  then begin TempByte := Byte(opLT);  Output.Write(TempByte, 1); end
      else if Command = 'GTE' then begin TempByte := Byte(opGTE); Output.Write(TempByte, 1); end
      else if Command = 'LTE' then begin TempByte := Byte(opLTE); Output.Write(TempByte, 1); end
      else if Command = 'AND' then begin TempByte := Byte(opAND); Output.Write(TempByte, 1); end
      else if Command = 'OR'  then begin TempByte := Byte(opOR);  Output.Write(TempByte, 1); end
      else if Command = 'NOT' then begin TempByte := Byte(opNOT); Output.Write(TempByte, 1); end
      else if Command = 'RET' then begin TempByte := Byte(opRET); Output.Write(TempByte, 1); end
      else if Command = 'LEAVE' then begin TempByte := Byte(opLEAVE); Output.Write(TempByte, 1); end
      else if Command = 'DUP' then begin TempByte := Byte(opDUP); Output.Write(TempByte, 1); end
      else if Command = 'POP' then begin TempByte := Byte(opPOP); Output.Write(TempByte, 1); end
      else if Command = 'PRINT' then begin TempByte := Byte(opPRINT); Output.Write(TempByte, 1); end
      else if Command = 'INPUT' then begin TempByte := Byte(opINPUT); Output.Write(TempByte, 1); end
      else if Command = 'HALT' then begin TempByte := Byte(opHALT); Output.Write(TempByte, 1); end
      else if Command = 'CAST_I' then begin TempByte := Byte(opCAST_I); Output.Write(TempByte, 1); end
      else if Command = 'CAST_F' then begin TempByte := Byte(opCAST_F); Output.Write(TempByte, 1); end
      else if Command = 'CONCAT' then begin TempByte := Byte(opCONCAT); Output.Write(TempByte, 1); end
      else if Command = 'STRLEN' then begin TempByte := Byte(opSTRLEN); Output.Write(TempByte, 1); end
      else if Command = 'ALLOC' then begin TempByte := Byte(opALLOC); Output.Write(TempByte, 1); end
      else if Command = 'SSET'  then begin TempByte := Byte(opSSET);  Output.Write(TempByte, 1); end
      else if Command = 'SGET'  then begin TempByte := Byte(opSGET);  Output.Write(TempByte, 1); end
      else if Command = 'FREE'  then begin TempByte := Byte(opFREE);  Output.Write(TempByte, 1); end
      else if Command = 'LEN'   then begin TempByte := Byte(opLEN);   Output.Write(TempByte, 1); end
      else if Command = 'NOP'   then begin TempByte := Byte(opNOP);   Output.Write(TempByte, 1); end
      else
        raise Exception.Create('SVM Assembler Hatasż: Geēersiz komut -> ' + Command);
    end;

    SetLength(Result, Output.Size);
    if Output.Size > 0 then
      Move(Output.Memory^, Result[0], Output.Size);
  finally
    Labels.Free; Lines.Free; Output.Free;
  end;
end;

end.
